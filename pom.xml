<?xml version="1.0" encoding="UTF-8"?>
<project xmlns="http://maven.apache.org/POM/4.0.0"
         xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
         xsi:schemaLocation="http://maven.apache.org/POM/4.0.0 http://maven.apache.org/xsd/maven-4.0.0.xsd">
    <modelVersion>4.0.0</modelVersion>

    <groupId>io.github.yamatrireddy</groupId>
    <artifactId>rsql-fiql-parser</artifactId>
    <version>1.0.0</version>
    <packaging>jar</packaging>

    <name>RSQL Parser</name>
    <description>A secure, enterprise-grade Java library for parsing RSQL/FIQL filter expressions
        into an Abstract Syntax Tree (AST). Supports Java 17, 21, 25, and 26 with JPMS module
        support, visitor pattern, configurable security limits, and zero mandatory dependencies.</description>
    <url>https://github.com/yamatrireddy/rsql-parser-java-21</url>
    <inceptionYear>2024</inceptionYear>

    <properties>
        <!-- Default baseline — override with a profile or -Djava.version=21 -->
        <java.version>17</java.version>
        <maven.compiler.release>${java.version}</maven.compiler.release>
        <project.build.sourceEncoding>UTF-8</project.build.sourceEncoding>
        <project.reporting.outputEncoding>UTF-8</project.reporting.outputEncoding>

        <!-- Dependency versions -->
        <mongodb.driver.version>5.3.0</mongodb.driver.version>
        <slf4j.version>2.0.17</slf4j.version>
        <junit.version>5.12.2</junit.version>
        <mockito.version>5.17.0</mockito.version>
        <assertj.version>3.27.7</assertj.version>

        <!-- Plugin versions -->
        <maven.compiler.plugin.version>3.14.0</maven.compiler.plugin.version>
        <maven.surefire.plugin.version>3.5.3</maven.surefire.plugin.version>
        <maven.source.plugin.version>3.3.1</maven.source.plugin.version>
        <maven.javadoc.plugin.version>3.11.2</maven.javadoc.plugin.version>
        <maven.gpg.plugin.version>3.2.8</maven.gpg.plugin.version>
        <central.publishing.plugin.version>0.7.0</central.publishing.plugin.version>
        <flatten.plugin.version>1.7.0</flatten.plugin.version>
    </properties>

    <licenses>
        <license>
            <name>MIT License</name>
            <url>https://opensource.org/licenses/MIT</url>
            <distribution>repo</distribution>
        </license>
    </licenses>

    <developers>
        <developer>
            <id>yamatrireddy</id>
            <name>Yamatri Reddy</name>
            <email>yamatri.tiss.nussd@gmail.com</email>
            <url>https://github.com/yamatrireddy</url>
        </developer>
    </developers>

    <scm>
        <connection>scm:git:git://github.com/yamatrireddy/rsql-parser-java-21.git</connection>
        <developerConnection>scm:git:ssh://git@github.com:yamatrireddy/rsql-parser-java-21.git</developerConnection>
        <url>https://github.com/yamatrireddy/rsql-parser-java-21</url>
        <tag>HEAD</tag>
    </scm>

    <issueManagement>
        <system>GitHub Issues</system>
        <url>https://github.com/yamatrireddy/rsql-parser-java-21/issues</url>
    </issueManagement>

    <dependencies>
        <!-- SLF4J API — consumers supply their own implementation (Logback, Log4j2, etc.) -->
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-api</artifactId>
            <version>${slf4j.version}</version>
        </dependency>

        <!--
            MongoDB Java Driver (Core) — optional.
            Required only when using MongoDbQueryBuilder. Consumers who want MongoDB
            support must declare this dependency themselves. Not pulled in transitively.
        -->
        <dependency>
            <groupId>org.mongodb</groupId>
            <artifactId>mongodb-driver-core</artifactId>
            <version>${mongodb.driver.version}</version>
            <optional>true</optional>
        </dependency>

        <!-- Test dependencies -->
        <dependency>
            <groupId>org.junit.jupiter</groupId>
            <artifactId>junit-jupiter</artifactId>
            <version>${junit.version}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.assertj</groupId>
            <artifactId>assertj-core</artifactId>
            <version>${assertj.version}</version>
            <scope>test</scope>
        </dependency>
        <dependency>
            <groupId>org.mockito</groupId>
            <artifactId>mockito-core</artifactId>
            <version>${mockito.version}</version>
            <scope>test</scope>
        </dependency>
        <!-- Logging implementation for tests only -->
        <dependency>
            <groupId>org.slf4j</groupId>
            <artifactId>slf4j-simple</artifactId>
            <version>${slf4j.version}</version>
            <scope>test</scope>
        </dependency>
    </dependencies>

    <build>
        <plugins>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-compiler-plugin</artifactId>
                <version>${maven.compiler.plugin.version}</version>
                <configuration>
                    <release>${maven.compiler.release}</release>
                    <showWarnings>true</showWarnings>
                    <showDeprecation>true</showDeprecation>
                    <compilerArgs>
                        <arg>-Xlint:all</arg>
                        <arg>-Xlint:-processing</arg>
                    </compilerArgs>
                </configuration>
            </plugin>
            <plugin>
                <groupId>org.apache.maven.plugins</groupId>
                <artifactId>maven-surefire-plugin</artifactId>
                <version>${maven.surefire.plugin.version}</version>
                <configuration>
                    <argLine>
                        --add-opens io.github.yamatrireddy.rsql/io.github.yamatrireddy=ALL-UNNAMED
                        --add-opens io.github.yamatrireddy.rsql/io.github.yamatrireddy.api=ALL-UNNAMED
                        --add-opens io.github.yamatrireddy.rsql/io.github.yamatrireddy.ast=ALL-UNNAMED
                        --add-opens io.github.yamatrireddy.rsql/io.github.yamatrireddy.lexer=ALL-UNNAMED
                        --add-opens io.github.yamatrireddy.rsql/io.github.yamatrireddy.optimizer=ALL-UNNAMED
                        --add-opens io.github.yamatrireddy.rsql/io.github.yamatrireddy.security=ALL-UNNAMED
                        --add-opens io.github.yamatrireddy.rsql/io.github.yamatrireddy.visitor=ALL-UNNAMED
                        --add-opens io.github.yamatrireddy.rsql/io.github.yamatrireddy.exception=ALL-UNNAMED
                    </argLine>
                </configuration>
            </plugin>
            <!-- CI-friendly flattened POM for published artifacts -->
            <plugin>
                <groupId>org.codehaus.mojo</groupId>
                <artifactId>flatten-maven-plugin</artifactId>
                <version>${flatten.plugin.version}</version>
                <configuration>
                    <updatePomFile>true</updatePomFile>
                    <flattenMode>resolveCiFriendliesOnly</flattenMode>
                </configuration>
                <executions>
                    <execution>
                        <id>flatten</id>
                        <phase>process-resources</phase>
                        <goals><goal>flatten</goal></goals>
                    </execution>
                    <execution>
                        <id>flatten.clean</id>
                        <phase>clean</phase>
                        <goals><goal>clean</goal></goals>
                    </execution>
                </executions>
            </plugin>
        </plugins>
    </build>

    <profiles>
        <!-- ═══════════════ Java-version profiles ═══════════════ -->
        <profile>
            <id>java-17</id>
            <properties><java.version>17</java.version></properties>
        </profile>
        <profile>
            <id>java-21</id>
            <properties><java.version>21</java.version></properties>
        </profile>
        <profile>
            <id>java-25</id>
            <properties><java.version>25</java.version></properties>
        </profile>
        <profile>
            <id>java-26</id>
            <properties><java.version>26</java.version></properties>
        </profile>

        <!-- ═══════════════ Release profile ═══════════════
             Activate with: mvn deploy -P release
             Requires: GPG key + Maven Central token in ~/.m2/settings.xml
             ═══════════════════════════════════════════════ -->
        <profile>
            <id>release</id>
            <build>
                <plugins>
                    <!-- 1. Sources JAR -->
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-source-plugin</artifactId>
                        <version>${maven.source.plugin.version}</version>
                        <executions>
                            <execution>
                                <id>attach-sources</id>
                                <goals><goal>jar-no-fork</goal></goals>
                            </execution>
                        </executions>
                    </plugin>

                    <!-- 2. Javadoc JAR -->
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-javadoc-plugin</artifactId>
                        <version>${maven.javadoc.plugin.version}</version>
                        <configuration>
                            <release>${maven.compiler.release}</release>
                            <doclint>all,-missing</doclint>
                            <quiet>true</quiet>
                            <failOnError>false</failOnError>
                        </configuration>
                        <executions>
                            <execution>
                                <id>attach-javadocs</id>
                                <goals><goal>jar</goal></goals>
                            </execution>
                        </executions>
                    </plugin>

                    <!-- 3. GPG signing (loopback mode works in CI with GNUPGHOME set) -->
                    <plugin>
                        <groupId>org.apache.maven.plugins</groupId>
                        <artifactId>maven-gpg-plugin</artifactId>
                        <version>${maven.gpg.plugin.version}</version>
                        <executions>
                            <execution>
                                <id>sign-artifacts</id>
                                <phase>verify</phase>
                                <goals><goal>sign</goal></goals>
                                <configuration>
                                    <gpgArguments>
                                        <arg>--pinentry-mode</arg>
                                        <arg>loopback</arg>
                                    </gpgArguments>
                                </configuration>
                            </execution>
                        </executions>
                    </plugin>

                    <!-- 4. Sonatype Central Publishing (new portal, replaces legacy OSSRH) -->
                    <plugin>
                        <groupId>org.sonatype.central</groupId>
                        <artifactId>central-publishing-maven-plugin</artifactId>
                        <version>${central.publishing.plugin.version}</version>
                        <extensions>true</extensions>
                        <configuration>
                            <!-- Matches <server id="central"> in ~/.m2/settings.xml -->
                            <publishingServerId>central</publishingServerId>
                            <autoPublish>true</autoPublish>
                            <waitUntil>published</waitUntil>
                        </configuration>
                    </plugin>
                </plugins>
            </build>
        </profile>
    </profiles>
</project>
